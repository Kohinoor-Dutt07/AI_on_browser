# ============================================
# AI BROWSER AGENT - CONFIGURATION
# ============================================

# Copy this file to .env and fill in your values

# ============================================
# LLM CONFIGURATION
# ============================================

# Choose provider: openai, anthropic, ollama, nim
LLM_PROVIDER=openai

# For OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# For Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# For Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# For NVIDIA NIM
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=mistralai/mixtral-8x22b-instruct-v0.1
NIM_API_KEY=your_nim_api_key_here

# ============================================
# BROWSER CONFIGURATION
# ============================================

# Browser: chrome, edge, firefox
BROWSER=chrome

# Headless mode: true (no GUI) or false (show browser)
HEADLESS=false

# Viewport size (width x height)
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# Custom user agent (leave empty for default)
USER_AGENT=

# ============================================
# STEALTH SETTINGS
# ============================================

# Enable stealth mode to avoid detection
STEALTH_MODE=true

# Disable automated flag
DISABLE_AUTOMATION_FLAG=true

# ============================================
# CREDENTIALS
# ============================================

# Store credentials as: CREDENTIALS_SITENAME=username|password
# Example:
# CREDENTIALS_LINKEDIN=myemail@example.com|mypassword
# CREDENTIALS_AMAZON=myuser|pass123

# ============================================
# BEHAVIORAL SETTINGS
# ============================================

# Random delay between actions (seconds)
MIN_DELAY=1
MAX_DELAY=3

# Typing speed: characters per second
TYPING_SPEED=30

# ============================================
# OUTPUT SETTINGS
# ============================================

# Save screenshots to this folder
SCREENSHOT_DIR=screenshots

# Save extracted data to this folder
DATA_DIR=data

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO